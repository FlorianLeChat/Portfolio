######################
# General parameters #
######################

## Analytics parameters
# > Data collection is made through umami, an open-source analytics solution: https://umami.is/
# > Enabling DNT (Do Not Track) user preference is recommended to respect user privacy: https://en.wikipedia.org/wiki/Do_Not_Track
PUBLIC_ANALYTICS_ENABLED=false
PUBLIC_ANALYTICS_ENDPOINT=http://localhost:3000/script.js
PUBLIC_ANALYTICS_PROJECT_ID=
PUBLIC_ANALYTICS_RESPECT_DNT=true
